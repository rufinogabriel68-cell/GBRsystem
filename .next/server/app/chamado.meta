{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/chamado/layout,_N_T_/chamado/page,_N_T_/chamado"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/chamado/__PAGE__",
    "/chamado",
    "/_index",
    "/_head"
  ]
}